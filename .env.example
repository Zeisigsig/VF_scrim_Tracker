DB_PATH=data/scrim.db

# (선택) Phase 2 전적 보강용 — 현재 미연결. 나중에 Henrik API 붙일 때 채우면 됨.
# HENRIK_API_KEY=

# 인증 (로그인 시스템)
# 세션 쿠키 서명 키 — 배포 시 무작위 값으로 반드시 교체 (예: python -c "import secrets;print(secrets.token_hex(32))")
SECRET_KEY=dev-insecure-change-me
# 어드민 사전발급 계정 공통 초기 비밀번호 (첫 로그인 시 강제 변경)
DEFAULT_PASSWORD=valorant
# 어드민 권한 디스코드 닉 (콤마 구분). 여기 적힌 계정만 관리 기능 사용 가능.
ADMIN_USERNAMES=

# --- 배포(로컬 OCR → 클라우드 웹) ---
# 로컬 push.py 와 클라우드 /api/ingest 가 공유하는 인증 시크릿(양쪽 동일 값).
#   생성 예: python -c "import secrets;print(secrets.token_hex(32))"
INGEST_API_KEY=
# [로컬 전용] push.py 가 추출 결과를 보낼 클라우드 주소. 예: https://xxx.ts.net
CLOUD_BASE_URL=
# 로컬(OCR 가능)=1 → /upload·/inbox 웹 업로드 허용. 클라우드(VM)=0.
ENABLE_LOCAL_UPLOAD=0
